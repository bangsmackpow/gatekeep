# ──────────────────────────────────────────────
# GateKeep - Environment Configuration
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
ENVIRONMENT=development
DOMAIN=localhost
LOG_LEVEL=info

# ── PostgreSQL ───────────────────────────────
POSTGRES_DB=gatekeep
POSTGRES_USER=gatekeep
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_123
POSTGRES_HOST_PORT=5432

# ── Elasticsearch ────────────────────────────
ELASTIC_PASSWORD=CHANGE_ME_ELASTIC_PASS_456
ELASTIC_HOST_PORT=9200

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS_789
REDIS_HOST_PORT=6379

# ── JWT / Session ────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS_LONG!!!

# ── Azure Storage ────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=gatekeep-artifacts

# ── Microsoft Entra ID (OIDC) ────────────────
ENTRA_TENANT_ID=YOUR_TENANT_ID
ENTRA_CLIENT_ID=YOUR_CLIENT_ID
ENTRA_CLIENT_SECRET=YOUR_CLIENT_SECRET
ENTRA_REDIRECT_URI=https://localhost/auth/callback

# ── Stirling-PDF ─────────────────────────────
STIRLING_HOST_PORT=8080

# ── Workers ──────────────────────────────────
WORKER_CONCURRENCY=2

# ── Flower (Celery Monitor) ──────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASS
FLOWER_HOST_PORT=5555

# ── SSL (Traefik / Let's Encrypt) ────────────
ACME_EMAIL=admin@yourfirm.com

# ── Host Port Overrides ──────────────────────
WEB_HOST_PORT=8000
